# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_PATH=./data/camera-monitor.db

# Storage
STORAGE_PATH=./recordings
MAX_STORAGE_GB=500
RETENTION_DAYS=30

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=*

# RTSP Configuration
RTSP_TIMEOUT=30000
STREAM_BUFFER_SIZE=2097152

# FFmpeg Paths
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe